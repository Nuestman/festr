# Neon database (optional — scripts, CLI, server code)
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Neon Auth — Vite reads this from the repo root `.env` in dev/build
# Neon Console → Project → Branch → Auth → Configuration → Auth Base URL
VITE_NEON_AUTH_URL=https://ep-xxx.neonauth.region.aws.neon.tech/neondb/auth
