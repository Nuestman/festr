# Copy to `.env.local` for local Next.js development.

# Neon — pooled connection string (server only). Required for Report, Map data, Dashboard, etc.
# Prefer defining this here; `next.config.ts` also merges `../.env` from the monorepo root if missing.
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Canonical site URL (OAuth redirects, absolute links). Must match `web/package.json` dev port (e.g. 17013) and Neon Auth redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:17013

# Neon Auth — Console → Project → Branch → Auth → Auth Base URL
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.region.aws.neon.tech/neondb/auth

# Neon Auth — server-only; generate a random 32+ character secret
NEON_AUTH_COOKIE_SECRET=

# Vercel Blob — read/write token; store should allow private blobs (uploads use private access; reads go through /api/... routes)
BLOB_READ_WRITE_TOKEN=

# Mapbox — public token for map + geocoding (restrict URLs in Mapbox dashboard)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Set to "true" only when Neon Auth env vars are configured and you want enforcement
AUTH_ENABLED=false

# Mirror AUTH_ENABLED for client UI (NeonAuthUIProvider, Sign in, UserButton). Set both when testing auth.
NEXT_PUBLIC_AUTH_ENABLED=false

# Optional: show a beta banner on marketing pages (e.g. previews)
NEXT_PUBLIC_BETA_BANNER=false

# UI palette: `neutral` = default shadcn-style greys (good for previews); `brand` = FESTR / Neon tokens
NEXT_PUBLIC_UI_PALETTE=neutral

# When true, footer shows Standard / Brand controls and localStorage can override env. When false, env always wins (clear stale keys: localStorage.removeItem('festr-ui-palette'))
NEXT_PUBLIC_SHOW_UI_PALETTE_TOGGLE=false

# Phase 6 — comma-separated emails that get responder/admin roles in `profiles` (staging bootstrap)
# FESTR_ADMIN_EMAILS=you@example.com
# FESTR_RESPONDER_EMAILS=responder@example.com

# Phase 7 — in-process rate limits (per instance; override for production tuning)
# RATE_LIMIT_REPORTS_PER_MINUTE=30
# RATE_LIMIT_UPLOADS_PER_MINUTE=20
# RATE_LIMIT_INCIDENT_LIST_PER_MINUTE=120

# Vercel Cron — protect /api/cron/purge-media (Bearer token; 16+ characters)
# CRON_SECRET=

# Days to keep incident media in Blob + DB; 0 = disable automated purge (default 90)
# MEDIA_RETENTION_DAYS=90
